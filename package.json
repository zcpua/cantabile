{
  "name": "cantabile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "tsx watch src/server/entry/node.ts",
    "build:api": "tsup --config tsup.config.ts",
    "seed:supabase": "node scripts/generate-supabase-seed.mjs",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate:pg": "drizzle-kit generate --config drizzle.pg.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config drizzle.pg.config.ts",
    "db:push:pg": "drizzle-kit push --config drizzle.pg.config.ts",
    "db:studio:pg": "drizzle-kit studio --config drizzle.pg.config.ts",
    "db:generate:d1": "drizzle-kit generate --config drizzle.d1.config.ts",
    "d1:migrations:apply:local": "wrangler d1 migrations apply cantabile --local",
    "d1:migrations:apply:remote": "wrangler d1 migrations apply cantabile --remote",
    "sync:supabase-to-d1": "node scripts/sync-supabase-to-d1.mjs",
    "sync:performances": "node scripts/sync-chncpa-performances.mjs --save && node scripts/sync-shso-performances.mjs --save && node scripts/sync-bjch-performances.mjs --save && node scripts/sync-shch-performances.mjs --save",
    "sync:chncpa": "node scripts/sync-chncpa-performances.mjs --save",
    "sync:chncpa:dry-run": "node scripts/sync-chncpa-performances.mjs",
    "sync:shso": "node scripts/sync-shso-performances.mjs --save",
    "sync:shso:dry-run": "node scripts/sync-shso-performances.mjs",
    "sync:bjch": "node scripts/sync-bjch-performances.mjs --save",
    "sync:bjch:dry-run": "node scripts/sync-bjch-performances.mjs",
    "sync:shch": "node scripts/sync-shch-performances.mjs --save",
    "sync:shch:dry-run": "node scripts/sync-shch-performances.mjs",
    "sync:wikidata": "node scripts/sync-wikidata.mjs --save",
    "sync:wikidata:dry-run": "node scripts/sync-wikidata.mjs --dry-run",
    "sync:imslp": "node scripts/sync-imslp.mjs --save",
    "sync:imslp:dry-run": "node scripts/sync-imslp.mjs --dry-run --max-pages 1",
    "match:classical-works": "node scripts/match-classical-works.mjs --save",
    "match:classical-works:dry-run": "node scripts/match-classical-works.mjs --dry-run --report-misses",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@hono/node-server": "^1.14.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@vercel/analytics": "^2.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "next": "16.2.7",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  }
}
